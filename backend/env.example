# Backend
NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:3000

# PostgreSQL
PG_DATABASE_URL=postgres://postgres:postgres@localhost:5432/soundy
PG_SSL=false

# Auth/session
SESSION_MAX_AGE_DAYS=7
JWT_SECRET=replace_with_strong_secret
JWT_EXPIRES_IN_MINUTES=60
BCRYPT_SALT_ROUNDS=10

# App settings
FAVORITES_PLAYLIST_NAME=favorite

# Absolute path to directory with tracks/covers/uploads
TRACKS_BASE_DIR=C:/Users/zengy/Documents/project/soundy/database/music
UPLOAD_TMP_DIR=C:/Users/zengy/Documents/project/soundy/database/.uploads_tmp

# OpenAI embeddings
OPENAI_API_KEY=sk-...
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
RECOMMENDATIONS_LIMIT=20