# Backend
NODE_ENV=production
PORT=4000
# Comma-separated list of allowed frontend origins (main + admin subdomain).
# Example: https://url.com,https://admin.url.com
CORS_ORIGIN=https://soundy.vercel.app
PLAYLIST_REALTIME_ENABLED=false
MEDIA_DRIVER=local

# PostgreSQL
# Railway service-to-service: prefer DATABASE_URL (private domain, no egress fees).
# Local machine: use PG_DATABASE_URL or DATABASE_PUBLIC_URL (public proxy).
PG_DATABASE_URL="postgresql://${{PGUSER}}:${{POSTGRES_PASSWORD}}@${{RAILWAY_TCP_PROXY_DOMAIN}}:${{RAILWAY_TCP_PROXY_PORT}}/${{PGDATABASE}}"
DATABASE_PUBLIC_URL="postgresql://${{PGUSER}}:${{POSTGRES_PASSWORD}}@${{RAILWAY_TCP_PROXY_DOMAIN}}:${{RAILWAY_TCP_PROXY_PORT}}/${{PGDATABASE}}"
DATABASE_URL="postgresql://${{PGUSER}}:${{POSTGRES_PASSWORD}}@${{RAILWAY_PRIVATE_DOMAIN}}:5432/${{PGDATABASE}}"
PG_SSL=true
PG_CONNECT_TIMEOUT_MS=3000
PG_QUERY_TIMEOUT_MS=5000
PG_IDLE_TIMEOUT_MS=10000
PG_MAX_CLIENTS=10
PGDATA="/var/lib/postgresql/data/pgdata"
PGDATABASE="${{POSTGRES_DB}}"
PGHOST="${{RAILWAY_PRIVATE_DOMAIN}}"
PGPASSWORD="${{POSTGRES_PASSWORD}}"
PGPORT="5432"
PGUSER="${{POSTGRES_USER}}"
POSTGRES_DB="railway"
POSTGRES_PASSWORD="ufmupYZdKXaqhKGQRpoMEPoxBLFcBzjI"
POSTGRES_USER="postgres"
RAILWAY_DEPLOYMENT_DRAINING_SECONDS="60"
SSL_CERT_DAYS="820"

# Auth
SESSION_MAX_AGE_DAYS=30
JWT_SECRET=generate_with_crypto
JWT_EXPIRES_IN_MINUTES=15
BCRYPT_SALT_ROUNDS=10

# App
FAVORITES_PLAYLIST_NAME=favorite

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=soundy
R2_PUBLIC_URL=https://pub-xxx.r2.dev
R2_ADS_OBJECT_KEY=ad/ads.opus

# OpenAI
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
RECOMMENDATIONS_LIMIT=20
