# Backend
NODE_ENV=production
PORT=4000
CORS_ORIGIN=https://soundy.vercel.app

# PostgreSQL (Railway даст эту строку)
PG_DATABASE_URL=postgresql://user:pass@host:5432/soundy
PG_SSL=true

# Auth
SESSION_MAX_AGE_DAYS=30
JWT_SECRET=сгенерируй_через_crypto
JWT_EXPIRES_IN_MINUTES=15
BCRYPT_SALT_ROUNDS=10

# App
FAVORITES_PLAYLIST_NAME=favorite

# Cloudflare R2 (вместо локальных путей)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=soundy
R2_PUBLIC_URL=https://pub-xxx.r2.dev

# OpenAI
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
RECOMMENDATIONS_LIMIT=20