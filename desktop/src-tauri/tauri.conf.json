{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Soundy Widget",
  "version": "0.1.0",
  "identifier": "com.soundy.widget",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Soundy Widget",
        "width": 320,
        "height": 120,
        "minWidth": 320,
        "minHeight": 120,
        "maxWidth": 320,
        "maxHeight": 120,
        "resizable": false,
        "alwaysOnTop": true,
        "decorations": false,
        "transparent": true,
        "skipTaskbar": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false
  }
}
